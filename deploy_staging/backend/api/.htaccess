# Disable ALL caching for PHP API files

# Standard Apache headers (for reverse proxies / CDNs)
<IfModule mod_headers.c>
    Header set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
    Header set Pragma "no-cache"
    Header set Expires "Thu, 01 Jan 1970 00:00:00 GMT"
</IfModule>

<IfModule mod_expires.c>
    ExpiresActive Off
</IfModule>

# LiteSpeed-specific: completely disable cache lookup for this directory
# This is the correct directive — NOT "CacheDisable"
CacheLookup off
