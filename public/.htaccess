<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Remove .html extension (optional redirect for cleaner URLs)
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME}.html -f
    RewriteRule ^([^\.]+)$ $1.html [NC,L]
</IfModule>

<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    # Vite hashes CSS/JS filenames, so they can be cached long-term safely
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType text/javascript "access plus 1 year"
    ExpiresByType application/pdf "access plus 1 month"
    ExpiresByType image/x-icon "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    # HTML must NEVER be cached — it points to the hashed assets of the current build
    ExpiresByType text/html "access plus 0 seconds"
</IfModule>

# Force revalidation of HTML on every request (Apache)
<IfModule mod_headers.c>
    <FilesMatch "\.(html|htm|php)$|^[^\.]+$">
        Header set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
        Header set Pragma "no-cache"
        Header set Expires "0"
    </FilesMatch>
</IfModule>

# LiteSpeed-specific: disable page cache for HTML files
<FilesMatch "\.(html|htm|php)$|^[^\.]+$">
    CacheLookup off
</FilesMatch>
